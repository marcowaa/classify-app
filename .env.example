# Classify - Environment Template
# Copy to .env and replace placeholders with real secrets (never commit real secrets)
# For production, start from .env.production.example and run npm run check-notifications:strict before release.

# Database
POSTGRES_USER=classify
POSTGRES_PASSWORD=replace_db_password
POSTGRES_DB=classify_db
DATABASE_URL=postgresql://classify:replace_db_password@127.0.0.1:5434/classify_db

# Security (generate strong 64-char hex)
JWT_SECRET=replace_jwt_secret
SESSION_SECRET=replace_session_secret
ADMIN_PANEL_PASSWORD=change_me_admin_panel

# Default Admin Account (created on first startup)
ADMIN_EMAIL=admin@classify.app
ADMIN_PASSWORD=change_me_admin_password

# ⚠️ IMPORTANT:
# After changing ADMIN_EMAIL or ADMIN_PASSWORD in this file:
# 1. Run: npm run admin:setup  (for local/docker development)
# 2. Or: docker-compose exec app npm run admin:setup  (for production)
# This syncs changes from .env to the database
# See: docs/ADMIN_CREDENTIALS.md for full guide

# Admin Security
ADMIN_CREATION_SECRET=replace_admin_creation_secret
ADMIN_BYPASS_EMAILS=

# Application
# For VPS production, use your public domain (not localhost)
APP_URL=https://classi-fy.com
NODE_ENV=production
CORS_ORIGIN=https://classi-fy.com
ALLOWED_ORIGINS=https://classi-fy.com

# SEO prerender (optional but recommended for SPA indexing)
# Set PRERENDER_TOKEN from your prerender.io dashboard.
# Keep PRERENDER_ENABLED=auto to enable automatically when token exists.
PRERENDER_ENABLED=auto
PRERENDER_TOKEN=
# Optional custom service URL (default is prerender.io service URL)
# PRERENDER_SERVICE_URL=https://service.prerender.io/

# Docker Compose isolation on shared server (recommended)
# Use a unique project name per app to isolate networks/volumes/container names.
COMPOSE_PROJECT_NAME=classify_prod

# Host port mapping (defaults chosen to avoid common conflicts with 80/443/5432/3000 etc.)
# Keep these when multiple projects share one VPS.
TRAEFIK_HTTP_PORT=18080
TRAEFIK_HTTPS_PORT=18443
POSTGRES_HOST_PORT=5434
MINIO_API_PORT=9102
MINIO_CONSOLE_PORT=9101

# Optional ports for docker-compose.http.yml tools
PORTAINER_WEB_PORT=19000
PORTAINER_EDGE_PORT=18000
PGADMIN_PORT=15050
REDIS_COMMANDER_PORT=18081
PROMETHEUS_PORT=19090
GRAFANA_PORT=13000
LOKI_PORT=13100
MAILHOG_SMTP_PORT=11025
MAILHOG_UI_PORT=18025

# Performance/Capacity (optional overrides)
# Balanced profile (recommended default)
NODE_CLUSTER_ENABLED=true
WEB_CONCURRENCY=4
DB_POOL_MAX=50
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=10000

# High-throughput profile (uncomment only after monitoring)
# NODE_CLUSTER_ENABLED=true
# WEB_CONCURRENCY=6
# DB_POOL_MAX=70
# DB_POOL_MIN=8
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECT_TIMEOUT_MS=10000

# SMTP (email)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@classi-fy.com
SMTP_PASSWORD=replace_smtp_password
SMTP_FROM="Classify <info@classi-fy.com>"

# RESEND (email provider)
RESEND_API_KEY=replace_resend_api_key

# Auth Feature Toggles (env-only)
AUTH_SOCIAL_LOGIN_ENABLED=true
AUTH_OTP_ENABLED=true

# Social OAuth Providers (env-only)
# Enable individual providers with <PROVIDER>_ENABLED=true and set credentials.
# Supported providers: google, facebook, apple, twitter, github, microsoft, linkedin, discord
# Google visibility rules:
# - Web OAuth button requires GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET.
# - Native (Capacitor) Google button can work with GOOGLE_CLIENT_ID,
#   or GOOGLE_ANDROID_CLIENT_ID / GOOGLE_CLIENT_ID_ANDROID.
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=replace_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_google_client_secret
GOOGLE_REDIRECT_URI=https://classi-fy.com/api/auth/oauth/google/callback
GOOGLE_SCOPES=email profile

# Native Android Google audience validation
GOOGLE_ANDROID_CLIENT_ID=replace_android_client_id.apps.googleusercontent.com

# Optional provider examples
#FACEBOOK_ENABLED=false
#FACEBOOK_CLIENT_ID=replace_facebook_client_id
#FACEBOOK_CLIENT_SECRET=replace_facebook_client_secret
#FACEBOOK_REDIRECT_URI=https://classi-fy.com/api/auth/oauth/facebook/callback

# OTP Providers (env-only)
OTP_EMAIL_ENABLED=true
OTP_SMS_ENABLED=false
OTP_WHATSAPP_ENABLED=false
OTP_CODE_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_MINUTES=1

# SMS / Twilio (optional; enable only if used)
#SMS_PROVIDER=twilio
#TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
#TWILIO_FROM_NUMBER=+10000000000

# WhatsApp OTP (optional)
#WHATSAPP_PROVIDER=twilio
#WHATSAPP_API_KEY=replace_whatsapp_api_key
#TWILIO_WHATSAPP_FROM=+14155238886

# Stripe (optional; required for paid store flows)
#STRIPE_SECRET_KEY=sk_live_replace_this
#STRIPE_PUBLISHABLE_KEY=pk_live_replace_this
#STRIPE_WEBHOOK_SECRET=whsec_replace_this

# in-home Shipping Connector (optional, non-blocking)
INHOME_SHIPPING_ENABLED=false
# Use a dedicated in-home domain (separate service + separate database from Classify)
INHOME_SHIPPING_BASE_URL=https://inhome.classi-fy.com
INHOME_SHIPPING_API_KEY=dk_live_replace_this
INHOME_SHIPPING_TIMEOUT_MS=5000
INHOME_SHIPPING_WEBHOOK_SECRET=replace_with_shared_webhook_secret
# Keep false in production to prevent localhost/private-network connector targets
INHOME_ALLOW_PRIVATE_HOSTS=false
PUBLIC_BASE_URL=https://classi-fy.com

# Web Push (Task Notification Level 4)
# Generate using: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@classify.app
VAPID_PUBLIC_KEY=replace_vapid_public_key
VAPID_PRIVATE_KEY=replace_vapid_private_key

# Mobile Push (FCM v1 preferred)
# Option A: Service account JSON inline (single-line JSON)
FCM_PROJECT_ID=replace_firebase_project_id
FCM_SERVICE_ACCOUNT_JSON=replace_service_account_json

# Task Notification Worker Profiles (Outbox processor)
# Choose one profile based on traffic volume:
# - low: small deployments / low event throughput
# - medium: recommended default for most production setups
# - high: heavy traffic (requires monitoring and enough DB/CPU capacity)
TASK_NOTIFICATION_WORKER_ENABLED=true
TASK_NOTIFICATION_WORKER_PROFILE=medium

# Dynamic autoscaling based on pending outbox backlog
TASK_NOTIFICATION_WORKER_AUTOSCALE=true
# TASK_NOTIFICATION_WORKER_BACKLOG_HIGH=96
# TASK_NOTIFICATION_WORKER_BACKLOG_CRITICAL=256
# TASK_NOTIFICATION_WORKER_MAX_BATCH_SIZE=180
# TASK_NOTIFICATION_WORKER_MAX_CONCURRENCY=20

# Optional manual overrides (take precedence over profile defaults)
# TASK_NOTIFICATION_WORKER_INTERVAL_MS=7000
# TASK_NOTIFICATION_WORKER_BATCH_SIZE=32
# TASK_NOTIFICATION_WORKER_CONCURRENCY=6

# Option B: use GOOGLE_APPLICATION_CREDENTIALS path instead of JSON inline
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Legacy fallback (deprecated by Google, kept for backward compatibility)
FCM_SERVER_KEY=replace_fcm_server_key

# ========== MONITORING TOOLS CREDENTIALS ==========
# Portainer: Auto-setup on first login
# pgAdmin: $ADMIN_EMAIL / $ADMIN_PASSWORD
# Grafana: admin / $ADMIN_PASSWORD
# Redis Commander: No auth required
# Prometheus: No auth required
# Loki: No auth required
# Mailhog: No auth required
